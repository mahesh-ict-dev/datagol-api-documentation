          example: c2cccdf27ebaaefeffeedee0ca4cceb9333b4f31e676e4531cc208b9725bc330
      responses:
        '200':
          description: Get Table Schema
      tags:
        - WorkBook
      description: >-
        ## 1️⃣ Overview


        **Purpose:**  

